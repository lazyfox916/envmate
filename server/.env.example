# ===========================================
# EnvMate Server Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=envmate
DB_USER=envmate
DB_PASSWORD=envmate_dev_password
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_SSL=false

# JWT Configuration
# Generate a secure random string for JWT_SECRET (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Configuration
# Generate a secure 32-byte key for AES-256 encryption
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (choose one provider)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# EMAIL_FROM=noreply@envmate.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
