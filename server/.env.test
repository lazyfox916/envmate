# Test Environment Configuration
# Copy to .env.test and adjust values as needed

NODE_ENV=test

# Database - Use separate test database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=envmate_test
DB_USER=postgres
DB_PASSWORD=postgres

# JWT - Use test secrets (never use in production)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption - Test key (32 bytes for AES-256)
ENCRYPTION_KEY=

# Server
PORT=3001
CORS_ORIGINS=http://localhost:3000

# Email - Disabled in tests
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=test@envmate.local

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000
